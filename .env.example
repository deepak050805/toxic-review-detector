# Environment configuration template for local development and hosted secrets.

# Flask runtime mode. Use production on hosted deployments.
FLASK_ENV=development
DEBUG=False

# Flask and Gunicorn port. Hosted platforms inject PORT automatically.
PORT=5000

# Replace in every non-local environment.
SECRET_KEY=replace-with-a-secure-value

# Transformer models (see models/model_loader.py):
# - unitary/toxic-bert
# - distilbert-base-uncased-finetuned-sst-2-english

# Optional: use cached weights only (no Hub download).
# TRANSFORMERS_OFFLINE=1
# HF_HUB_OFFLINE=1

# PyTorch-only backend (do not install TensorFlow in this project).
TRANSFORMERS_NO_TF=1
USE_TF=0
USE_TORCH=1

# CPU thread limits for low-memory hosts (Render free tier).
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
