# Environment configuration template for local development and hosted secrets.

# Flask runtime mode. Use production on hosted deployments.
FLASK_ENV=development
DEBUG=False

# Flask and Gunicorn port. Hosted platforms may override this value.
PORT=5000

# Replace in every non-local environment.
SECRET_KEY=replace-with-a-secure-value

# Current transformer model references used by models/model_loader.py.
# - unitary/toxic-bert
# - lxyuan/distilbert-base-multilingual-cased-sentiments-student

# Optional GPU selection for CUDA-enabled hosts.
# CUDA_VISIBLE_DEVICES=0
